{
  "ignore": {
    "rules": ["react-doctor/effect-needs-cleanup"],
    "files": [
      ".dumi/**",
      "docs/**",
      "tests/**",
      "scripts/**",
      "**/demo/**",
      "**/__tests__/**",
      "**/*.md"
    ],
    "overrides": [
      {
        "files": ["components/form/Form.tsx", "components/input/Input.tsx"],
        "rules": ["react-hooks/rules-of-hooks"]
      }
    ]
  },
  "failOn": "none",
  "adoptExistingLintConfig": true
}
